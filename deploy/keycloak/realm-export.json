  "webAuthnPolicyPasswordlessCreateTimeout": 0,
  "webAuthnPolicyPasswordlessAvoidSameAuthenticatorRegister": false,
  "webAuthnPolicyPasswordlessAcceptableAaguids": [],
  "browserFlow": "browser",
  "registrationFlow": "registration",
  "directGrantFlow": "direct grant",
  "resetCredentialsFlow": "reset credentials",
  "clientAuthenticationFlow": "clients",
  "dockerAuthenticationFlow": "docker auth",
  "attributes": {
    "frontendUrl": "${authBaseUrl}",
    "cibaBackchannelTokenDeliveryMode": "poll",
    "cibaExpiresIn": "120",
    "cibaInterval": "5",
    "cibaAuthRequestedUserHint": "login_hint",
    "parRequestUriLifespan": "60",
    "oauth2DeviceCodeLifespan": "600",
    "oauth2DevicePollingInterval": "5"
  },
  "keycloakVersion": "24.0.0",
  "userManagedAccessAllowed": false,
  "clientProfiles": {
    "profiles": []
  },
  "clientPolicies": {
    "policies": []
  },
  "roles": {
    "realm": [
      {
        "id": "admin-role",
        "name": "admin",
        "description": "管理用户、车辆、策略、审计、录制",
        "composite": false,
        "composites": {},
        "clientRole": false,
        "containerId": "teleop"
      },
      {
        "id": "owner-role",
        "name": "owner",
        "description": "账号拥有者：管理自己账号下 VIN 的绑定、授权",
        "composite": false,
        "composites": {},
        "clientRole": false,
        "containerId": "teleop"
      },
      {
        "id": "operator-role",
        "name": "operator",
        "description": "可申请控制指定 VIN（需被授权）",
        "composite": false,
        "composites": {},
        "clientRole": false,
        "containerId": "teleop"
      },
      {
        "id": "observer-role",
        "name": "observer",
        "description": "仅拉流查看指定 VIN（需被授权）",
        "composite": false,
        "composites": {},
        "clientRole": false,
        "containerId": "teleop"
      },
      {
        "id": "maintenance-role",
        "name": "maintenance",
        "description": "查看故障/诊断，可进行受限操作",
        "composite": false,
        "composites": {},
        "clientRole": false,
        "containerId": "teleop"
      }
    ],
    "client": {}
  },
