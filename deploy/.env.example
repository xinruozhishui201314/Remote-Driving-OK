# Docker Compose 环境变量示例文件
# 复制此文件为 .env 并修改相应的值

# PostgreSQL
POSTGRES_PASSWORD=teleop_password_change_in_prod

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB_PASSWORD=keycloak_password_change_in_prod
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_PORT=8080

# Keycloak Client Secrets（生产环境必须修改）
TELEOP_BACKEND_CLIENT_SECRET=change-me-in-production-backend-secret
TELEOP_CLIENT_CLIENT_SECRET=change-me-in-production-client-secret

# Coturn
COTURN_USERNAME=teleop
COTURN_PASSWORD=teleop_turn_password_change_in_prod
# 如果服务器在 NAT 后，需要指定公网 IP
# COTURN_EXTERNAL_IP=your.public.ip.address

# ZLMediaKit
# 如果服务器在 NAT 后，需要指定公网 IP（用于 WebRTC）
# ZLM_EXTERN_IP=your.public.ip.address

# 分布式部署：Backend 返回给 Client/车端的 WHEP/WHIP 基地址（Client/车端能访问的 ZLM 地址）
# 不设则使用 ZLM_API_URL 的 host:port
# ZLM_PUBLIC_BASE=https://media.yourcompany.com

# MQTT Broker (Mosquitto)
# 分布式部署时填 Client 与车端都能访问的 Broker 地址（Backend 会下发给 Client）
# MQTT_BROKER_URL=mqtts://mqtt.yourcompany.com:8883
MQTT_VEHICLE_PASSWORD=vehicle_password_change_in_prod
MQTT_CLIENT_PASSWORD=client_password_change_in_prod
MQTT_ADMIN_PASSWORD=admin_password_change_in_prod

# ===============================================================================
# CARLA 仿真器配置（docker-compose.carla.yml）
# ===============================================================================
# CARLA_GPU_RENDER_MODE: offscreen=EGL GPU 无头(默认) / offscreen-x11=X11 DISPLAY / window=显示窗口
#   offscreen (默认): GPU 加速无头渲染，无需 DISPLAY/X11，相机帧率可达 15+ FPS（推荐）
#   offscreen-x11: 依赖 DISPLAY 环境变量，无 DISPLAY 时用 llvmpipe 软件渲染（FPS 极低）
#   window: 显示 CARLA 仿真窗口，需 DISPLAY + xhost +local:docker
# CARLA_GPU_RENDER_MODE=offscreen

# CARLA_SHOW_WINDOW: 0=无头(默认) / 1=窗口模式（覆盖 GPU_RENDER_MODE，强制使用窗口）
# CARLA_SHOW_WINDOW=0

# DISPLAY: 仅 window / offscreen-x11 模式需要。offscreen 模式不需要 DISPLAY（entrypoint 会清除）。
# DISPLAY=:0

# 测试模式：跳过 CARLA 相机，使用 ffmpeg testsrc 生成测试视频流
#   FORCE_TESTSRC=1: 完全跳过 CARLA 相机，始终使用 testsrc（无 GPU 环境验证）
#   USE_TESTSRC_FALLBACK=1: 若 CARLA 相机 10s 内 < 3fps，自动降级到 testsrc（默认开启）
# FORCE_TESTSRC=0
# USE_TESTSRC_FALLBACK=1

# 相机推流帧率（建议 15，GPU 性能差时可降到 10）
# CAMERA_FPS=15

# CARLA 地图
# CARLA_MAP=Town01
