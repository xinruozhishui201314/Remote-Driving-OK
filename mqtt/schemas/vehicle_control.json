{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:teleop:schemas:vehicle_control:1.2.0",
  "title": "MQTT vehicle/control message",
  "version": "1.2.0",
  "description": "Wire-format JSON on vehicle/control. Use timestampMs (ms epoch) and schemaVersion semver string. See docs/TELEOP_SIGNAL_CONTRACT.md.",
  "oneOf": [
    { "$ref": "#/definitions/remote_control" },
    { "$ref": "#/definitions/start_stream" },
    { "$ref": "#/definitions/stop_stream" },
    { "$ref": "#/definitions/drive" },
    { "$ref": "#/definitions/steering" },
    { "$ref": "#/definitions/throttle" },
    { "$ref": "#/definitions/brake" },
    { "$ref": "#/definitions/gear" },
    { "$ref": "#/definitions/target_speed" },
    { "$ref": "#/definitions/emergency_stop" },
    { "$ref": "#/definitions/sweep" },
    { "$ref": "#/definitions/mode_light" },
    { "$ref": "#/definitions/ui_envelope" }
  ],
  "definitions": {
    "semver": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "vin_req": {
      "type": "string",
      "minLength": 1
    },
    "remote_control": {
      "type": "object",
      "required": ["type", "vin", "schemaVersion", "seq", "timestampMs", "enable"],
      "properties": {
        "type": { "const": "remote_control" },
        "vin": { "$ref": "#/definitions/vin_req" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "seq": { "type": "integer", "minimum": 0 },
        "timestampMs": { "type": "integer" },
        "enable": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "start_stream": {
      "type": "object",
      "required": ["type", "vin", "schemaVersion", "seq", "timestampMs"],
      "properties": {
        "type": { "const": "start_stream" },
        "vin": { "$ref": "#/definitions/vin_req" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "seq": { "type": "integer", "minimum": 0 },
        "timestampMs": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "stop_stream": {
      "type": "object",
      "required": ["type", "vin", "schemaVersion", "seq", "timestampMs"],
      "properties": {
        "type": { "const": "stop_stream" },
        "vin": { "$ref": "#/definitions/vin_req" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "seq": { "type": "integer", "minimum": 0 },
        "timestampMs": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "drive": {
      "type": "object",
      "required": [
        "type",
        "vin",
        "schemaVersion",
        "seq",
        "timestampMs",
        "steering",
        "throttle",
        "brake",
        "gear",
        "emergency_stop"
      ],
      "properties": {
        "type": { "const": "drive" },
        "vin": { "$ref": "#/definitions/vin_req" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "seq": { "type": "integer", "minimum": 0 },
        "timestampMs": { "type": "integer" },
        "steering": { "type": "number", "minimum": -1.0, "maximum": 1.0 },
        "throttle": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "brake": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "gear": { "type": "integer" },
        "emergency_stop": { "type": "boolean" },
        "sessionId": { "type": "string" },
        "trace_id": { "type": "string" },
        "nonce": { "type": "string" },
        "signature": { "type": "string" },
        "predicted_steering": { "type": "number" },
        "prediction_horizon_ms": { "type": "number" }
      },
      "additionalProperties": false
    },
    "steering": {
      "type": "object",
      "required": ["type", "vin", "schemaVersion", "seq", "timestampMs", "value"],
      "properties": {
        "type": { "const": "steering" },
        "vin": { "$ref": "#/definitions/vin_req" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "seq": { "type": "integer", "minimum": 0 },
        "timestampMs": { "type": "integer" },
        "value": { "type": "number", "minimum": -1.0, "maximum": 1.0 }
      },
      "additionalProperties": false
    },
    "throttle": {
      "type": "object",
      "required": ["type", "vin", "schemaVersion", "seq", "timestampMs", "value"],
      "properties": {
        "type": { "const": "throttle" },
        "vin": { "$ref": "#/definitions/vin_req" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "seq": { "type": "integer", "minimum": 0 },
        "timestampMs": { "type": "integer" },
        "value": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      },
      "additionalProperties": false
    },
    "brake": {
      "type": "object",
      "required": ["type", "vin", "schemaVersion", "seq", "timestampMs", "value"],
      "properties": {
        "type": { "const": "brake" },
        "vin": { "$ref": "#/definitions/vin_req" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "seq": { "type": "integer", "minimum": 0 },
        "timestampMs": { "type": "integer" },
        "value": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      },
      "additionalProperties": false
    },
    "gear": {
      "type": "object",
      "required": ["type", "vin", "schemaVersion", "seq", "timestampMs", "value"],
      "properties": {
        "type": { "const": "gear" },
        "vin": { "$ref": "#/definitions/vin_req" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "seq": { "type": "integer", "minimum": 0 },
        "timestampMs": { "type": "integer" },
        "value": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "target_speed": {
      "type": "object",
      "required": ["type", "vin", "schemaVersion", "seq", "timestampMs", "value"],
      "properties": {
        "type": { "const": "target_speed" },
        "vin": { "$ref": "#/definitions/vin_req" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "seq": { "type": "integer", "minimum": 0 },
        "timestampMs": { "type": "integer" },
        "value": { "type": "number", "minimum": 0.0, "maximum": 100.0 }
      },
      "additionalProperties": false
    },
    "emergency_stop": {
      "type": "object",
      "required": ["type", "vin", "schemaVersion", "seq", "timestampMs", "enable"],
      "properties": {
        "type": { "const": "emergency_stop" },
        "vin": { "$ref": "#/definitions/vin_req" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "seq": { "type": "integer", "minimum": 0 },
        "timestampMs": { "type": "integer" },
        "enable": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "sweep": {
      "type": "object",
      "required": ["type", "vin", "schemaVersion", "seq", "timestampMs", "sweepType", "active"],
      "properties": {
        "type": { "const": "sweep" },
        "vin": { "$ref": "#/definitions/vin_req" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "seq": { "type": "integer", "minimum": 0 },
        "timestampMs": { "type": "integer" },
        "sweepType": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "mode_light": {
      "type": "object",
      "required": ["type", "vin", "schemaVersion", "seq", "timestampMs", "subType", "lightType", "active"],
      "properties": {
        "type": { "const": "mode" },
        "vin": { "$ref": "#/definitions/vin_req" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "seq": { "type": "integer", "minimum": 0 },
        "timestampMs": { "type": "integer" },
        "subType": { "const": "light" },
        "lightType": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "ui_envelope": {
      "type": "object",
      "required": [
        "type",
        "payload",
        "vin",
        "schemaVersion",
        "sessionId",
        "timestampMs",
        "seq",
        "trace_id"
      ],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "payload": { "type": "object" },
        "vin": { "$ref": "#/definitions/vin_req" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "sessionId": { "type": "string" },
        "timestampMs": { "type": "integer" },
        "seq": { "type": "integer", "minimum": 0 },
        "trace_id": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
