{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:teleop:schemas:vehicle_status:1.2.0",
  "title": "MQTT vehicle/status message",
  "version": "1.2.0",
  "description": "vehicle/status carries periodic chassis, remote_control_ack, encoder_hint_ack, offline (LWT). Chassis uses timestamp (ms epoch). Control plane uses timestampMs — see vehicle_control.json.",
  "oneOf": [
    { "$ref": "#/definitions/vehicle_status_chassis" },
    { "$ref": "#/definitions/remote_control_ack" },
    { "$ref": "#/definitions/encoder_hint_ack" },
    { "$ref": "#/definitions/offline" }
  ],
  "definitions": {
    "semver": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "vehicle_status_chassis": {
      "type": "object",
      "required": ["type", "vin", "timestamp", "schemaVersion"],
      "properties": {
        "type": { "const": "vehicle_status" },
        "vin": { "type": "string" },
        "timestamp": { "type": "integer", "description": "Wall clock ms since epoch" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "speed": { "type": "number", "minimum": 0.0 },
        "battery": { "type": "number", "minimum": 0.0, "maximum": 100.0 },
        "brake": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "throttle": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "steering": { "type": "number", "minimum": -1.0, "maximum": 1.0 },
        "gear": { "type": "integer" },
        "odometer": { "type": "number", "minimum": 0.0 },
        "temperature": { "type": "number" },
        "voltage": { "type": "number" },
        "remote_control_enabled": { "type": "boolean" },
        "driving_mode": { "type": "string" },
        "streaming": { "type": "boolean" },
        "network_rtt": { "type": "number" },
        "sweep_active": { "type": "boolean" },
        "network_quality": { "type": "object" },
        "sessionId": { "type": "string" }
      },
      "additionalProperties": true
    },
    "remote_control_ack": {
      "type": "object",
      "required": [
        "type",
        "timestamp",
        "schemaVersion",
        "remote_control_enabled",
        "driving_mode"
      ],
      "properties": {
        "type": { "const": "remote_control_ack" },
        "vin": { "type": "string" },
        "timestamp": { "type": "integer" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "remote_control_enabled": { "type": "boolean" },
        "driving_mode": { "type": "string" }
      },
      "additionalProperties": false
    },
    "encoder_hint_ack": {
      "type": "object",
      "required": ["type", "timestamp", "schemaVersion"],
      "properties": {
        "type": { "const": "encoder_hint_ack" },
        "vin": { "type": "string" },
        "timestamp": { "type": "integer" },
        "schemaVersion": { "$ref": "#/definitions/semver" },
        "originalType": { "type": "string" },
        "stream": { "type": "string" },
        "preferH264SingleSlice": { "type": "boolean" },
        "actionTaken": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": true
    },
    "offline": {
      "type": "object",
      "required": ["type", "vin", "timestamp", "schemaVersion"],
      "properties": {
        "type": { "const": "offline" },
        "vin": { "type": "string" },
        "timestamp": { "type": "integer" },
        "schemaVersion": { "$ref": "#/definitions/semver" }
      },
      "additionalProperties": false
    }
  }
}
