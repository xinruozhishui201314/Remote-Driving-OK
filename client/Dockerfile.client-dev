# client-dev 完备镜像：Qt6 + 镜像内安装 libdatachannel（+ FFmpeg），启动容器即可编译/运行客户端并接收视频
#
# 构建（默认用 BuildKit 层缓存，避免无谓全量重编）：
#   docker compose -f docker-compose.yml -f docker-compose.client-dev.yml build client-dev
#
# 国内 Qt 二进制镜像加速（可选，与 aqtinstall -b 一致，末尾保留 /qt/）：
#   export AQT_BASE=https://mirrors.tuna.tsinghua.edu.cn/qt/
#   docker compose -f docker-compose.yml -f docker-compose.client-dev.yml build client-dev
#
# 或 docker build：
#   docker build -f client/Dockerfile.client-dev -t remote-driving-client-dev:full \
#     --build-arg AQT_BASE=https://mirrors.tuna.tsinghua.edu.cn/qt/ client/
#
# 若本地已有 remote-driving-client-dev:full，只需在其上叠小改动（不重编 libdatachannel / 完整 Qt）：
#   见 Dockerfile.client-dev.from-full + docker-compose.client-dev.from-full.yml
#
# 多阶段：在 Ubuntu 中编译 libdatachannel 再复制到 Qt 镜像，避免在 Qt 基础镜像中 apt 权限问题

# ---------- 阶段 1：在 Ubuntu 中编译并安装 libdatachannel ----------
FROM docker.1ms.run/library/ubuntu:22.04 AS libdatachannel-builder
RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake \
    git \
    build-essential \
    libssl-dev \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# 避免 Docker 构建时 git clone 出现 "Error in the HTTP2 framing layer"（网络/代理环境常见）
RUN git config --global http.version HTTP/1.1 \
    && git config --global http.postBuffer 524288000

ARG LIBDC_VERSION=master
RUN git clone --depth 1 https://github.com/paullouisageneau/libdatachannel.git /tmp/libdatachannel \
    && cd /tmp/libdatachannel \
    && git submodule update --init --recursive --depth 1 \
    && cmake -B build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/opt/libdatachannel \
        -DUSE_GNUTLS=OFF \
        -DUSE_NICE=OFF \
        -DNO_EXAMPLES=ON \
        -DNO_TESTS=ON \
    && cmake --build build -j$(nproc 2>/dev/null || echo 4) \
    && cmake --install build \
    && rm -rf /tmp/libdatachannel

# ---------- 阶段 2：Qt6 镜像 + 拷贝 libdatachannel + 安装 qsb ----------
FROM docker.1ms.run/stateoftheartio/qt6:6.8-gcc-aqt

# 从阶段 1 拷贝已安装的 libdatachannel（无需在 Qt 镜像内 apt 编译工具）
COPY --from=libdatachannel-builder /opt/libdatachannel /opt/libdatachannel

# 系统依赖与 Qt 模块分两层：仅调整 aqt 参数/版本时不必重跑 apt（利用 Docker 缓存）
# qsb：QSGMaterialShader 必需；qtmultimedia：QVideoSink / VideoOutput
USER root
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        libavcodec-dev \
        libavutil-dev \
        libswscale-dev \
        libavformat-dev \
        pkg-config \
        fonts-wqy-zenhei \
        cmake \
        make \
        g++ \
        mosquitto-clients \
        libxcb-cursor0 \
        libxcb-xfixes0 \
        libgl1-mesa-dev \
        mesa-utils \
        libpulse0 \
        libpulse-dev \
        libva-dev \
        libva-drm2 \
        libdrm-dev \
        python3-pip \
        curl \
        unzip \
    && rm -rf /var/lib/apt/lists/* \
    && fc-cache -fv

# AQT_BASE：Qt 官方下载镜像（可选），见文件头示例
ARG AQT_BASE=
ARG QT_DESKTOP_VERSION=6.8.0
ARG QT_DESKTOP_ARCH=linux_gcc_64
RUN set -eux; \
    if [ -n "${AQT_BASE}" ]; then \
        aqt install-qt -b "${AQT_BASE}" -O /opt/Qt \
            linux desktop "${QT_DESKTOP_VERSION}" "${QT_DESKTOP_ARCH}" \
            -m qtshadertools -m qtmultimedia; \
    else \
        aqt install-qt -O /opt/Qt \
            linux desktop "${QT_DESKTOP_VERSION}" "${QT_DESKTOP_ARCH}" \
            -m qtshadertools -m qtmultimedia; \
    fi; \
    test -x "/opt/Qt/${QT_DESKTOP_VERSION}/gcc_64/bin/qsb"; \
    echo "✓ qsb + Qt Multimedia -> /opt/Qt/${QT_DESKTOP_VERSION}/gcc_64"; \
    "/opt/Qt/${QT_DESKTOP_VERSION}/gcc_64/bin/qsb" --version 2>&1 | grep -v "Detected locale" | head -1; \
    pip3 uninstall -y aqtinstall pyzstd brotli py7zr pybcj psutil 2>/dev/null || true; \
    apt-get update -qq \
    && apt-get purge -y python3-dev build-essential python3-pip 2>/dev/null || true \
    && rm -rf /var/lib/apt/lists/* \
    && echo "✓ ShaderTools + Multimedia 安装完成"

# 编译时默认能找到 Qt + libdatachannel（与 QT_DESKTOP_VERSION 一致）
ENV CMAKE_PREFIX_PATH=/opt/Qt/${QT_DESKTOP_VERSION}/gcc_64:/opt/libdatachannel
ENV LD_LIBRARY_PATH=/opt/Qt/${QT_DESKTOP_VERSION}/gcc_64/lib:${LD_LIBRARY_PATH:-}
ENV PATH=/opt/Qt/${QT_DESKTOP_VERSION}/gcc_64/bin:${PATH:-}

WORKDIR /workspace
ENV DISPLAY=:0
CMD ["/bin/bash"]
