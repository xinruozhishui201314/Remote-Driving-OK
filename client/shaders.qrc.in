<RCC>
    <!--
        Shader resources for VideoRenderer GPU rendering.
        Generated by CMake configure_file() during build.
        Maps: @SHADER_GEN_DIR@/video.vert.qsb → qrc:/shaders/video.vert.qsb
        Maps: @SHADER_GEN_DIR@/video.frag.qsb → qrc:/shaders/video.frag.qsb
    -->
    <qresource prefix="/shaders">
        <file alias="video.vert.qsb">@SHADER_GEN_DIR@/video.vert.qsb</file>
        <file alias="video.frag.qsb">@SHADER_GEN_DIR@/video.frag.qsb</file>
    </qresource>
</RCC>
