# C++ / CMake Build Files
build/
bin/
lib/
# scripts/lib/ is versioned shell/Python helpers (sourced by start-full-chain.sh, verify-*.sh).
# The blanket lib/ rule above would otherwise ignore this directory.
!scripts/lib/
!scripts/lib/**
out/
*.o
*.obj
*.lib
*.a
*.so
*.dll
*.dylib
*.exe
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json

